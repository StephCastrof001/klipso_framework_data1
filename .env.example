# LLM Provider — elige uno: openai | bedrock | ollama | auto
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...

# AWS Bedrock (alternativa)
BEDROCK_API_KEY=BedrockAPIKey-xxx-xxxxxxxxxxxxxxxxxxxxxxxxx
AWS_DEFAULT_REGION=us-east-1

# Ollama local (gratis — para medir el 9B en EC2 sin gastar OpenAI)
# LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1

# Modelo A — "IA solo al final" (E-LLM-FINAL ganador 2/2: 600s timeout -> ~210s).
# false = recon/eda/hypothesis deterministicos, LLM solo en business_tx (Agente 4).
LLM_INTERMEDIATE=false
